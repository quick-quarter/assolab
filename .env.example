# ─── Ollama ───────────────────────────────────────────────────────────────────
# Local dev: http://localhost:11434
# Docker:    set automatically via docker-compose.yml (http://ollama:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Model to use. Options:
#   llama3.2:3b   — fast, 2 GB RAM, good for POC (default)
#   llama3.1:8b   — better quality, 8 GB RAM
#   mistral:7b    — excellent French, 4 GB RAM
#   qwen2.5:7b    — great multilingual, 5 GB RAM
OLLAMA_MODEL=llama3.2:3b

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
